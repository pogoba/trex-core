diff --git a/src/dpdk/lib/vhost/vduse.h b/src/dpdk/lib/vhost/vduse.h
index 47ca97a06..5eb1d8591 100644
--- a/src/dpdk/lib/vhost/vduse.h
+++ b/src/dpdk/lib/vhost/vduse.h
@@ -9,7 +9,18 @@
 
 #define VDUSE_NET_SUPPORTED_FEATURES VIRTIO_NET_SUPPORTED_FEATURES
 
-int vduse_device_create(const char *path, bool compliant_ol_flags);
-int vduse_device_destroy(const char *path);
+/* TREX/Nix: VDUSE disabled (its kernel uapi header is not bundled). Only the
+ * vhost-user socket transport is used, which never invokes these (they are
+ * called solely for is_vduse sockets). Stub them so vduse.c can be dropped. */
+static inline int vduse_device_create(const char *path, bool compliant_ol_flags)
+{
+	(void)path; (void)compliant_ol_flags;
+	return -1;
+}
+static inline int vduse_device_destroy(const char *path)
+{
+	(void)path;
+	return -1;
+}
 
 #endif /* _VDUSE_H */
