diff --git a/src/drivers/trex_driver_virtual.h b/src/drivers/trex_driver_virtual.h
index a6ff3e1cc..5be956f7a 100755
--- a/src/drivers/trex_driver_virtual.h
+++ b/src/drivers/trex_driver_virtual.h
@@ -58,6 +58,18 @@ public:
     virtual void update_configuration(port_cfg_t * cfg);
 };
 
+/* TREX/Nix: vhost-user vdevs - net_vhost (backend) and net_virtio_user (frontend),
+ * used to wire two TRex instances together over a unix socket. Same queue/offload
+ * configuration as virtio, but these are pure software vdevs with no PCI device. */
+class CTRexExtendedDriverVhost : public CTRexExtendedDriverVirtio {
+public:
+    CTRexExtendedDriverVhost() {}
+    static CTRexExtendedDriverBase * create(){
+        return ( new CTRexExtendedDriverVhost() );
+    }
+    virtual TRexPortAttr* create_port_attr(tvpid_t tvpid, repid_t repid);
+};
+
 class CTRexExtendedDriverVmxnet3 : public CTRexExtendedDriverVirtBase {
 public:
     CTRexExtendedDriverVmxnet3();
